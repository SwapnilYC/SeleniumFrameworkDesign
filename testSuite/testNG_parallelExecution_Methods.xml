		<classes>
			<class name="designFrameworkUsingTestNG.tests.SubmitOrderTest" />
		</classes>
	</test> <!-- SubmitOrderTest: Contains 2 tests(will pass) -->

	<test name="ErrorValidationTest">
		<classes>
			<class
				name="designFrameworkUsingTestNG.tests.ErrorValidationsTest" />
		</classes>
	</test> <!-- ErrorValidationTest: contains 2 test cases (Will fail both) -->

