<?xml version="1.0" encoding="UTF-8"?>
<suite name="DesignFrameworkUsingTestNG">
	<listeners>
		<listener
			class-name="designFrameworkUsingTestNG.reusableTestComponents.Listeners" />
	</listeners>
	<test name="Error Validations Tests only">
		<groups>
			<run>
				<include name="ErrorHandling" />
			</run>
		</groups>
		<classes>
			<class
				name="designFrameworkUsingTestNG.tests.ErrorValidationsTest" /><!-- SubmitOrderTest: 
				Contains 2 tests(only one follows grouping) -->
			<class name="designFrameworkUsingTestNG.tests.SubmitOrderTest" /> <!-- SubmitOrderTest: Contains 2 tests(No grouping) -->
		</classes>
	</test>
</suite> <!-- This script will execute only one test -->


<!-- for each type of grouping there must be seperatetestNG.xml file -->

